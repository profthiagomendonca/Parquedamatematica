[gd_scene load_steps=4 format=3]

[ext_resource type="Texture2D" path="res://assets/Cartola.png" id="1_cartola"]

[sub_resource type="GDScript" id="GDScript_magica_item"]
script/source = "extends PanelContainer

var identifier: int = 0
signal item_pressed(id)

@onready var texture_rect = $TextureRect
@onready var label = $CenterContainer/Label
@onready var button = $Button

var base_color: Color

func setup(id: int, col: Color):
	identifier = id
	base_color = col
	label.text = str(id)
	
	# Aplica cor dim (apagada) como padrão na cartola neutra
	texture_rect.modulate = base_color.darkened(0.5)
	
	button.pressed.connect(_on_pressed)

func _on_pressed():
	item_pressed.emit(identifier)

func pisca():
	var tween = create_tween().set_trans(Tween.TRANS_SINE)
	# Muda a saturação pra ultra clara simulando lâmpada
	tween.tween_property(texture_rect, \"modulate\", base_color.lightened(0.7), 0.1)
	tween.tween_property(texture_rect, \"modulate\", base_color.darkened(0.5), 0.4)
	
	# Efeito pula/mola com pivot de centro
	var t_scale = create_tween().set_trans(Tween.TRANS_ELASTIC).set_ease(Tween.EASE_OUT)
	self.pivot_offset = self.size / 2.0
	self.scale = Vector2.ONE * 1.15
	t_scale.tween_property(self, \"scale\", Vector2.ONE, 0.5)

func acende():
	texture_rect.modulate = base_color.lightened(0.7)
	
func apaga():
	texture_rect.modulate = base_color.darkened(0.5)

func set_color_wrong():
	texture_rect.modulate = Color.RED
"

